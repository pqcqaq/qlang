{
  "name": "qlang",
  "displayName": "qlang",
  "description": "VS Code language support for Qlang via qlsp.",
  "version": "0.1.0",
  "publisher": "qlang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pqcqaq/qlang.git"
  },
  "homepage": "https://github.com/pqcqaq/qlang",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:qlang",
    "onCommand:qlang.restartLanguageServer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "qlang",
        "aliases": ["Qlang", "qlang"],
        "extensions": [".ql"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "qlang",
        "scopeName": "source.qlang",
        "path": "./syntaxes/qlang.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "qlang.restartLanguageServer",
        "title": "Qlang: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "qlang",
      "properties": {
        "qlang.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path or workspace-relative path to a version-matched `qlsp` executable. Leave empty to prefer repo-local `target/debug/qlsp`, then `target/release/qlsp`, and finally fall back to `qlsp` on PATH."
        },
        "qlang.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Additional command-line arguments passed to `qlsp`."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test:grammar": "node scripts/check-grammar.js",
    "watch": "tsc -w -p ./",
    "prepublishOnly": "npm run compile",
    "package:vsix": "npm run compile && node -e \"const fs=require('fs'); const cp=require('child_process'); const pkg=require('./package.json'); fs.mkdirSync('dist',{recursive:true}); const out=`dist/qlang-${pkg.version}.vsix`; const result=cp.spawnSync('npx',['@vscode/vsce','package','--out',out],{stdio:'inherit',shell:process.platform==='win32'}); process.exit(result.status ?? 1);\""
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  },
  "vsce": {
    "yarn": false
  }
}
